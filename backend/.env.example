# Copy to .env and fill in real values. Never commit .env.

# MongoDB Atlas (free M0 cluster) — grab the SRV connection string from Atlas → Connect.
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=chessai

# JWT — generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Comma-separated list of allowed origins (no spaces).
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Optional: explicit Stockfish path; otherwise auto-discovered (see backend/app/engines/stockfish.py).
# STOCKFISH_BIN=
